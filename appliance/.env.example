# TNG Computer appliance settings. The defaults are right for almost everyone —
# you can run with this file untouched.

# Enable the audio-extraction fallback for embed-blocked music (YouTube).
# Off by default on distributed installs; set 1 to opt in.
TNG_AUDIO_FALLBACK=0

# Point at a different Tricorder cloud (self-hosters only).
#TNG_TRICORDER_URL=wss://myhome.computer/link

# Extra hostnames the Computer may reach through its egress fence,
# comma-separated (e.g. a home automation bridge).
#TNG_EXTRA_ALLOWED_DOMAINS=
