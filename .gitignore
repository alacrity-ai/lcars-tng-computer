# deps / build
node_modules/
dist/
# viewscreen stage build artifact (TNGC-37): `pnpm -C apps/tricorder build:vs`
# regenerates it; wrangler deploy ships it as static assets under /vs/.
apps/tricorder/public/vs/
.cache/
.wrangler/
*.tsbuildinfo
.venv/
__pycache__/
*.egg-info/

# secrets & local config
.env
.env.*
!.env.example
*.token
spotify-tokens.json
DO_NOT_COMMIT.md

# voice assets — never commit reference clips, cloned voices, or model weights
# (earcons/sound effects under apps/web/public are fine to commit)
voice/reference/*
voice/training/*
!voice/reference/.gitkeep
!voice/training/.gitkeep
!voice/training/NOTES.md
*.pt
*.pth
*.onnx
*.safetensors

# Windows download sidecars
*Zone.Identifier

# misc
.DS_Store
*.log

# Claude Code session-local state (the committed Computer persona lives in
# claude/.claude — this is only the root-level local settings dir)
/.claude/
**/.claude/settings.local.json
.pnpm-store/

# generated at boot by docker/plugin-merge.sh from .mcp.base.json + enabled plugins
claude/.mcp.json
# loader-generated plugin skills (plugin-merge.sh syncs these every boot)
claude/.claude/skills/plugin-*/
