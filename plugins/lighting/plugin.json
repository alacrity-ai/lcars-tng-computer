{
  "id": "lighting",
  "name": "Zigbee Lighting",
  "version": "0.1.0",
  "minCore": "0.3.0",
  "description": "Local Zigbee lighting fabric — Mosquitto + Zigbee2MQTT sidecars, lights MCP tool, LIGHTING wall panel. Fully local, no cloud.",
  "services": [
    { "name": "mosquitto" },
    { "name": "zigbee2mqtt" },
    { "name": "lighting", "internalEndpoints": [{ "host": "lighting", "port": 7101 }] }
  ],
  "mcp": { "name": "lights", "command": "node", "args": ["../plugins/lighting/mcp/server.mjs"] },
  "skills": ["lighting"],
  "allowedDomains": []
}
